
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Details of the registered user (Teacher or Student).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "standard": { "type": "string" },
        "school": { "type": "string" },
        "district": { "type": "string" },
        "taluka": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "standard", "district"]
    },
    "ExamPaperSettings": {
      "title": "Exam Paper Settings",
      "description": "Configuration settings for a generated exam paper including school and location details.",
      "type": "object",
      "properties": {
        "state": { "type": "string" },
        "district": { "type": "string", "description": "The district in Gujarat." },
        "taluka": { "type": "string", "description": "The taluka or city in the district." },
        "board": { "type": "string" },
        "classLevel": { "type": "string" },
        "subject": { "type": "string" },
        "chapters": { "type": "string" },
        "totalMarks": { "type": "number" },
        "language": { "type": "string" },
        "schoolName": { "type": "string" },
        "timeAllowed": { "type": "string" },
        "schoolLogo": { "type": "string", "format": "uri" },
        "blueprintText": { "type": "string" }
      },
      "required": ["state", "district", "board", "classLevel", "subject", "chapters", "totalMarks", "language", "schoolName"]
    },
    "ExamPaper": {
      "title": "Exam Paper",
      "description": "A generated exam paper document.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "settings": { "$ref": "#/backend/entities/ExamPaperSettings" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "settings", "content"]
    },
    "StudentMastery": {
      "title": "Student Mastery",
      "description": "Tracks concept mastery for a specific subject for a student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "progress": { "type": "number", "minimum": 0, "maximum": 100 },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "progress"]
    },
    "FocusSession": {
      "title": "Focus Session",
      "description": "Records a study session in Focus Mode.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "durationMinutes", "completedAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores profile details of teachers and students."
    },
    "/papers/{paperId}": {
      "schema": { "$ref": "#/backend/entities/ExamPaper" },
      "description": "Stores individual exam papers generated by users."
    },
    "/mastery/{masteryId}": {
      "schema": { "$ref": "#/backend/entities/StudentMastery" },
      "description": "Stores progress data for different subjects."
    },
    "/focus_sessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/FocusSession" },
      "description": "Stores records of distraction-free study sessions."
    }
  }
}
