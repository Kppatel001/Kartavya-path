{
  "entities": {
    "ExamPaperSettings": {
      "title": "Exam Paper Settings",
      "description": "Configuration settings for a generated exam paper.",
      "type": "object",
      "properties": {
        "state": { "type": "string" },
        "board": { "type": "string" },
        "classLevel": { "type": "string" },
        "subject": { "type": "string" },
        "chapters": { "type": "string" },
        "totalMarks": { "type": "number" },
        "language": { "type": "string" },
        "schoolLogo": { "type": "string", "format": "uri" },
        "sectionAQuestions": { "type": "number" },
        "sectionBQuestions": { "type": "number" },
        "sectionCQuestions": { "type": "number" },
        "sectionDQuestions": { "type": "number" }
      },
      "required": ["state", "board", "classLevel", "subject", "chapters", "totalMarks", "language"]
    },
    "ExamPaper": {
      "title": "Exam Paper",
      "description": "A generated exam paper document.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "settings": { "$ref": "#/backend/entities/ExamPaperSettings" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "settings", "content"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/papers/{paperId}": {
      "schema": { "$ref": "#/backend/entities/ExamPaper" },
      "description": "Stores individual exam papers generated by users."
    }
  }
}
